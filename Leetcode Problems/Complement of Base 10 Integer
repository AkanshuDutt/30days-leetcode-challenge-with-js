/**
 * @param {number} n
 * @return {number}
 */
var bitwiseComplement = function(n) {
    let str='';
    let ans=0;

    if(n===0) return 1;

    while(n>0){
        str=str+n%2;
        n=Math.floor(n/2);
    }
    console.log(str);

    for(let i=0;i<str.length;i++){
        if(str[i]==='0') ans+=Math.pow(2,i);
    }
    

    return ans;
};
