var rotate = function(grid) {
    const n = grid.length;
    for (let i = 0; i < n; i++)
        for (let j = i; j < n; j++)
            [grid[i][j], grid[j][i]] = [grid[j][i], grid[i][j]] ;
    for (let i = 0; i < n; i++)
        for (let j = 0; j < Math.floor(n/2); j++)
            [grid[i][j], grid[i][n-j-1]] = [grid[i][n-j-1], grid[i][j]] ;
};
