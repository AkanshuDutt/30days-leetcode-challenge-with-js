
const findMin = nums => {
    const dnc = (left, right) => {
        if (left === right)
            return nums[left];

        if (nums[left] < nums[right])
            return nums[left];

        const m = (left + right) >> 1;

        return Math.min(
            dnc(left, m),
            dnc(m + 1, right)
        );
    };

    return dnc(0, nums.length - 1);
};
